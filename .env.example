# SSH port (avoid 22). Real value comes from the SSH_PORT GitHub secret,
# left blank here so it isn't public in a public repo.
SSH_PORT=

# Pi-hole web admin password (FTLCONF_webserver_api_password)
PIHOLE_WEBPASSWORD=

# CUPS print server admin password
CUPS_ADMIN_PASSWORD=

# LAN IP of this server (netplan, Pi-hole reply host, CUPS advertised address)
SERVER_IP=

# Timezone for all containers (e.g. America/Guatemala)
TZ=

# DuckDNS token (Let's Encrypt DNS-01 wildcard cert via Traefik). See README DuckDNS section.
DUCKDNS_TOKEN=

# Full domain used for all internal hostnames — the FULL DuckDNS domain my-domain.duckdns.org,
DUCKDNS_DOMAIN=

# Email for Let's Encrypt expiry notices
ACME_EMAIL=
